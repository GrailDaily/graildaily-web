---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
---

<Layout
  title={`Sign Up | ${config.site.title}`}
  description="Create your GrailDaily account."
>
  <Header />

  <Main pageTitle="Create Account" narrow hideTitle>
    <section
      class="mx-auto flex min-h-[70vh] max-w-5xl items-center justify-center px-6 py-16"
    >
      <div
        class="bg-background w-full max-w-md rounded-3xl border border-gray-700 p-12"
      >
        <h1 class="text-center text-3xl font-bold">Create your account</h1>

        <p class="text-muted-foreground mt-5 text-center leading-7">
          Create your GrailDaily account to save articles, build your reading
          list, and receive personalized recommendations.
        </p>

        <div class="mt-8 space-y-5">
          <a
            href="#"
            class="hover:bg-muted flex h-12 items-center justify-center rounded-full border border-gray-600 transition"
          >
            Continue with Google
          </a>

          <div class="flex items-center gap-4">
            <div class="bg-border h-px flex-1"></div>

            <span
              class="text-muted-foreground text-xs tracking-widest uppercase"
            >
              or
            </span>

            <div class="bg-border h-px flex-1"></div>
          </div>

          <a
            href="#"
            class="bg-accent flex h-12 items-center justify-center rounded-full text-white transition hover:opacity-90"
          >
            Create account with Email
          </a>
        </div>

        <p class="mt-8 text-center text-sm">
          Already have an account?

          <a
            href="/login"
            class="text-accent ml-1 font-semibold hover:underline"
          >
            Sign In
          </a>
        </p>
      </div>
    </section>
  </Main>
</Layout>
