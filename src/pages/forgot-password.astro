---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
---

<Layout
  title={`Forgot Password | ${config.site.title}`}
  description="Reset your GrailDaily password."
>
  <Header />

  <Main pageTitle="Forgot Password" narrow hideTitle>
  <section class="mx-auto flex min-h-[70vh] max-w-5xl items-center justify-center px-6 py-16">

    <div class="w-full max-w-md rounded-3xl border border-gray-700 bg-background p-12">

      <h1 class="text-center text-3xl font-bold">
  Forgot your password?
</h1>

      <p class="mt-5 text-center text-muted-foreground leading-7">
        Enter your email address and we'll send you a link to reset your password.
      </p>

      <div class="mt-8 space-y-5">

  <a
    href="#"
    class="flex h-12 items-center justify-center rounded-full bg-accent text-white transition hover:opacity-90"
  >
    Send Reset Link
  </a>

  

</div>

      <p class="mt-8 text-center text-sm">
  Remember your password?

  <a
    href="#"
    class="ml-1 font-semibold text-accent hover:underline"
  >
    Sign In
  </a>
</p>

    </div>

  </section>
</Main>

  <Footer />
</Layout>