---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";
import Footer from "@/components/Footer.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import HeroCarousel from "@/components/hero/HeroCarousel.astro";
import Trending from "@/components/home/Trending.astro";
import Categories from "@/components/home/Categories.astro";
import Newsletter from "@/components/home/Newsletter.astro";
import EditorPicks from "@/components/home/EditorPicks.astro";
import RecentPosts from "@/components/home/RecentPosts.astro";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
console.log("=== POSTS ===");

posts.forEach(post => {
  console.log({
    id: post.id,
    title: post.data.title,
    featured: post.data.featured,
  });
});
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts
  .filter(({ data }) => data.featured)
  .slice(0, 6);

const recentPosts = sortedPosts.slice(0, 10);

const categories = [
  {
    name: "Archaeology",
    description: "Ancient discoveries",
    href: "/tags/archaeology",
    image: "/images/categories/Archaeology.png",
  },
  {
    name: "Economics",
    description: "Markets & trade",
    href: "/tags/economics",
    image: "/images/categories/Economics.png",
  },
  {
    name: "Entertainment",
    description: "Movies, music & more",
    href: "/tags/entertainment",
    image: "/images/categories/Entertainment.png",
  },
  {
    name: "Geography",
    description: "Places & regions",
    href: "/tags/geography",
    image: "/images/categories/Geography.png",
  },
  {
    name: "History",
    description: "Explore the past",
    href: "/tags/history",
    image: "/images/categories/History.png",
  },
  {
    name: "Humanity",
    description: "People & culture",
    href: "/tags/humanity",
    image: "/images/categories/Humanity.png",
  },
  {
    name: "Mysteries",
    description: "Unsolved secrets",
    href: "/tags/mysteries",
    image: "/images/categories/Mysteries.png",
  },
  {
    name: "Mythology",
