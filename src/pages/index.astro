---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";

import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";
import Footer from "@/components/Footer.astro";

import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import Hero from "@/components/Hero.astro";

import Trending from "@/components/home/Trending.astro";
import Categories from "@/components/home/Categories.astro";
import Newsletter from "@/components/home/Newsletter.astro";
import EditorPicks from "@/components/home/EditorPicks.astro";
import RecentPosts from "@/components/home/RecentPosts.astro";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

const categories = [
  {
    name: "History",
    description: "Ancient civilizations, lost empires, historical events",
    href: "/tags/history",
  },
  {
    name: "Science",
    description: "Discoveries, theories, space, and research",
    href: "/tags/science",
  },
  {
    name: "Mystery",
    description: "Unexplained phenomena and unsolved cases",
    href: "/tags/mystery",
  },
  {
    name: "Civilization",
    description: "Lost cultures, archaeology, ancient knowledge",
    href: "/tags/civilization",
  },
];
---

<Layout>
  <Header />
  <Hero />

  <Trending posts={recentPosts} />

  <Categories categories={categories} />

  <Newsletter />

  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >

  <EditorPicks posts={featuredPosts} />

  <RecentPosts
    posts={recentPosts}
    title={t.home.recentPosts}
    limit={postsConfig.perIndex}
  />

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>

