---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";

import CategoryNavigation from "@/components/categories/CategoryNavigation.astro";

import config from "@/config";
import { categories } from "@/data/categories";
import CategorySection from "@/components/categories/CategorySection.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);
---

<Layout
  title={`Categories | ${config.site.title}`}
  description="Explore every category on GrailDaily."
>
  <Header />

  <CategoryNavigation categories={categories} />

  {
    categories.map((category, index) => {
      const categoryPosts = posts.filter(post =>
        post.data.tags?.includes(category.name)
      );

      return (
        <CategorySection
          category={category}
          index={index}
          posts={categoryPosts}
        />
      );
    })
  }
</Layout>
