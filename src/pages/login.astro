---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
---

<Layout
  title={`Login | ${config.site.title}`}
  description="Sign in to your GrailDaily account."
>
  <Header />

  <Main pageTitle="Welcome Back" narrow hideTitle>
  <section class="mx-auto flex min-h-[70vh] max-w-5xl items-center justify-center px-6 py-16">

    <div class="w-full max-w-md rounded-3xl border border-gray-700 bg-background p-12">

      <h1 class="text-center text-3xl font-bold">
  Welcome Back
</h1>

      <p class="mt-5 text-center text-muted-foreground leading-7">
        Sign in to access your bookmarks, personalized recommendations,
        and exclusive GrailDaily features.
      </p>

      <div class="mt-8 space-y-5">

  <a
    href="#"
    class="flex h-12 items-center justify-center rounded-full border border-gray-600 transition hover:bg-muted"
  >
    Continue with Google
  </a>

  <div class="flex items-center gap-4">

    <div class="h-px flex-1 bg-border"></div>

    <span class="text-xs uppercase tracking-widest text-muted-foreground">
      or
    </span>

    <div class="h-px flex-1 bg-border"></div>

  </div>

  <a
    href="#"
    class="flex h-12 items-center justify-center rounded-full bg-accent text-white transition hover:opacity-90"
  >
    Continue with Email
  </a>

  

</div>

<p class="mt-5 text-center text-sm">
  <a
    href="#"
    class="text-muted-foreground hover:text-accent"
  >
    Forgot your password?
  </a>
</p>

      <p class="mt-8 text-center text-sm">
  Don't have an account?

  <a
    href="#"
    class="ml-1 font-semibold text-accent hover:underline"
  >
    Sign Up
  </a>
</p>

    </div>

  </section>
</Main>

  <Footer />
</Layout>