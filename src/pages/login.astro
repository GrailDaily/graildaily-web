---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
---

<Layout
  title={`Login | ${config.site.title}`}
  description="Sign in to your GrailDaily account."
>
  <Header />

  <Main pageTitle="Welcome Back" narrow hideTitle>
    <section
      class="mx-auto flex min-h-[70vh] max-w-5xl items-center justify-center px-6 py-16"
    >
      <div
        class="bg-background w-full max-w-md rounded-3xl border border-gray-700 p-12"
      >
        <h1 class="text-center text-3xl font-bold">Welcome Back</h1>

        <p class="text-muted-foreground mt-5 text-center leading-7">
          Sign in to access your bookmarks, personalized recommendations, and
          exclusive GrailDaily features.
        </p>

        <div class="mt-8 space-y-5">
          <a
            href="#"
            class="hover:bg-muted flex h-12 items-center justify-center rounded-full border border-gray-600 transition"
          >
            Continue with Google
          </a>

          <div class="flex items-center gap-4">
            <div class="bg-border h-px flex-1"></div>

            <span
              class="text-muted-foreground text-xs tracking-widest uppercase"
            >
              or
            </span>

            <div class="bg-border h-px flex-1"></div>
          </div>

          <a
            href="#"
            class="bg-accent flex h-12 items-center justify-center rounded-full text-white transition hover:opacity-90"
          >
            Continue with Email
          </a>
        </div>

        <p class="mt-5 text-center text-sm">
          <a href="#" class="text-muted-foreground hover:text-accent">
            Forgot your password?
          </a>
        </p>

        <p class="mt-8 text-center text-sm">
          Don't have an account?

          <a href="#" class="text-accent ml-1 font-semibold hover:underline">
            Sign Up
          </a>
        </p>
      </div>
    </section>
  </Main>
</Layout>
