---
interface Props {
  size?: number;
  strokeWidth?: number;
}

const {
  size = 20,
  strokeWidth = 2,
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <circle cx="11" cy="11" r="7" />
  <path d="M20 20l-3.5-3.5" />
</svg>