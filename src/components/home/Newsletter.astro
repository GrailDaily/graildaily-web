---
import { Mail } from "@/components/icons/Icons.astro";
---

<section class="newsletter">
  <div class="app-layout">
    <div class="newsletter-box">
      <div class="newsletter-container">
        <div class="newsletter-left">
          <div class="newsletter-icon">
            <Mail size={32} stroke-width={2} />
          </div>

          <div class="newsletter-text">
            <h2>Stay Curious. Discover More.</h2>

            <p>
              Get the latest stories about ancient civilizations, mysteries,
              science, archaeology, and unexplained discoveries delivered
              directly to your inbox.
            </p>
          </div>
        </div>

        <div class="newsletter-right">
          <form class="newsletter-form">
            <input
              type="email"
              placeholder="Enter your email address"
              aria-label="Email address"
            />

            <button type="submit"> Subscribe </button>
          </form>

          <p class="newsletter-note">No spam. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .newsletter {
    padding: 20px 0;
    margin: 0;
  }

  .newsletter-box:hover {
    border-color: var(--accent);

    transform: translateY(-3px);
  }

  .newsletter-container {
    display: grid;
    grid-template-columns: 1fr 480px;

    align-items: center;

    gap: 56px;

    max-width: 1320px;

    margin: 0 auto;
  }

  .newsletter h2 {
    font-size: 2.3rem;

    font-weight: 700;

    line-height: 1.2;

    margin-bottom: 18px;

    color: var(--foreground);
  }

  .newsletter-container > p {
    max-width: 620px;

    margin: 0 auto 34px;

    line-height: 1.8;

    color: var(--muted-foreground);

    text-align: center;
  }

  .newsletter-form {
    display: flex;
    gap: 12px;
  }

  .newsletter input {
    flex: 1;

    max-width: 100%;

    padding: 16px 18px;

    border-radius: 14px;

    border: 1px solid var(--border);

    background: var(--background);

    color: var(--foreground);

    font-size: 1rem;

    transition: border-color 0.25s ease;
  }

  .newsletter input:focus {
    outline: none;

    border-color: var(--accent);
  }

  .newsletter button {
    padding: 16px 28px;

    border: none;

    border-radius: 14px;

    background: #d6b066;

    color: #142a4a;

    font-weight: 700;

    cursor: pointer;

    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .newsletter button:hover {
    background: #ffb84d;

    transform: translateY(-2px);
  }

  .newsletter-note {
    margin-top: 18px;

    font-size: 0.9rem;

    color: var(--muted-foreground);
  }

  .newsletter-box {
    padding: 36px 32px;

    border-radius: 20px;

    border: 1px solid var(--border);

    background: color-mix(in srgb, var(--background) 96%, white 4%);

    transition:
      border-color 0.25s ease,
      transform 0.25s ease;
  }

  .newsletter-left {
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .newsletter-icon {
    width: 64px;
    height: 64px;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 16px;

    background: rgba(214, 176, 102, 0.12);

    color: #d6b066;

    flex-shrink: 0;
  }

  .newsletter-text h2 {
    margin-bottom: 14px;
  }

  .newsletter-text p {
    margin: 0;
  }

  .newsletter-right {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  @media (max-width: 900px) {
    .newsletter-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .newsletter-left {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .newsletter-right {
      width: 100%;
    }

    .newsletter-form {
      flex-direction: column;
    }

    .newsletter-form input,
    .newsletter-form button {
      width: 100%;
    }

    .newsletter button {
      padding: 16px;
    }

    .newsletter-box {
      padding: 24px;
    }

    .newsletter h2 {
      font-size: 1.8rem;
    }
  }

  @media (max-width: 640px) {
    .newsletter h2 {
      font-size: 1.7rem;
    }

    .newsletter-text {
      text-align: center;
    }
  }
</style>
