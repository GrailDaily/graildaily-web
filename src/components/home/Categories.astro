---
interface Category {
  name: string;
  description: string;
  href: string;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

<section id="categories" class="categories">

  <h2 class="title">
    Explore Categories
  </h2>

  <div class="cat-grid">

    {categories.map((category) => (

      <a
        class="cat-card"
        href={category.href}
      >

        <h3>{category.name}</h3>

        <p>{category.description}</p>

      </a>

    ))}

  </div>

</section>

<style>
.categories {
  padding: 50px 0;
}

.title {
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 18px;
  color: #142A4A;
}

.cat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.cat-card {
  display: block;
  padding: 18px;

  border-radius: 14px;

  border: 1px solid #E6E9EE;

  background: #FFFFFF;

  text-decoration: none;

  transition:
    transform .2s ease,
    border-color .2s ease,
    box-shadow .2s ease;
}

.cat-card:hover {
  transform: translateY(-4px);

  border-color: #D6B066;

  box-shadow: 0 10px 25px rgba(20, 42, 74, 0.08);
}

.cat-card h3 {
  margin-bottom: .5rem;

  color: #142A4A;

  font-size: 1rem;
}

.cat-card p {
  color: #64748B;

  line-height: 1.6;

  font-size: .9rem;
}


/* Dark Mode */

:global(html.dark) .title {
  color: #FFFFFF;
}

:global(html.dark) .cat-card {

  background: #1E293B;

  border-color: #334155;
}

:global(html.dark) .cat-card:hover {

  border-color: #D6B066;

}

:global(html.dark) .cat-card h3 {

  color: #FFFFFF;

}

:global(html.dark) .cat-card p {

  color: #CBD5E1;

}


@media (max-width:900px) {

  .cat-grid {
    grid-template-columns: repeat(2,1fr);
  }

}


@media (max-width:768px) {

  .cat-grid {
    grid-template-columns: 1fr;
  }

}
</style>