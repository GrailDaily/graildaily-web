---
import ThemeToggle from "./ThemeToggle.astro";
---

<div class="actions">
  <button
    id="search-button"
    class="search-btn"
    type="button"
    aria-label="Search"
  >
    🔍
  </button>

  <ThemeToggle />
</div>

<script>
  function initHeaderActions() {
    const button = document.getElementById("search-button");

    if (!button) return;

    button.addEventListener("click", () => {
      document.dispatchEvent(new Event("open-search"));
    });
  }

  initHeaderActions();

  document.addEventListener("astro:after-swap", initHeaderActions);
</script>

<style>
.actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.search-btn {
  background: transparent;
  border: 1px solid rgba(255,255,255,.15);
  color: white;
  padding: 6px 10px;
  border-radius: 8px;
  cursor: pointer;
  transition: .2s;
}

.search-btn:hover {
  background: rgba(255,255,255,.08);
}
</style>