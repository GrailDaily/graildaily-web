---
import ThemeToggle from "./ThemeToggle.astro";
import SearchIcon from "../icons/SearchIcon.astro";
// import LoginButton from "./LoginButton.astro";
// import SubscribeButton from "./SubscribeButton.astro";
---

<div class="actions">
  <button
    id="search-button"
    class="search-btn"
    type="button"
    aria-label="Search"
  >
    <SearchIcon />
  </button>

  <ThemeToggle />
  {
    /* }<LoginButton />
  <SubscribeButton /> */
  }
</div>

<script>
  function initHeaderActions() {
    const button = document.getElementById("search-button");

    if (!button) return;

    button.addEventListener("click", () => {
      document.dispatchEvent(new Event("open-search"));
    });
  }

  initHeaderActions();

  document.addEventListener("astro:after-swap", initHeaderActions);
</script>

<style>
  .actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .search-btn {
    width: 44px;
    height: 44px;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 0;

    color: var(--foreground);

    background: transparent;

    border: 1px solid var(--border);

    border-radius: 10px;

    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      transform 0.15s ease;
  }

  .search-btn:hover {
    color: var(--accent);
    border-color: var(--accent);

    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .search-btn:active {
    transform: scale(0.96);
  }

  .search-btn svg {
    width: 20px;
    height: 20px;

    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .actions {
      display: none;
    }
  }
</style>
