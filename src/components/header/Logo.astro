---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";
import logoLight from "@/assets/images/logo/logo-light.png";
import logoDark from "@/assets/images/logo/logo-dark.png";

const locale = Astro.currentLocale ?? config.site.lang;
---

<a
  href={getRelativeLocaleUrl(locale, "")}
  class="flex items-center shrink-0"
  aria-label="GrailDaily Home"
>
  <img
    src={logoLight.src}
    alt="GrailDaily"
    class="h-12 w-auto transition-transform duration-300 dark:hidden lg:h-14"
  />

  <img
    src={logoDark.src}
    alt="GrailDaily"
    class="hidden h-12 w-auto transition-transform duration-300 dark:block lg:h-14"
  />
</a>