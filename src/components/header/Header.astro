---

import ThemeToggle from "./ThemeToggle.astro";
import SearchModal from "./SearchModal.astro";
import DesktopNav from "./DesktopNav.astro";
import Logo from "./Logo.astro";
---



<header class="site-header">
  <div class="container">
    
    <!-- Logo -->
    <Logo />

    <!-- Navigation -->
    <DesktopNav />

    <!-- Actions -->
    <div class="actions">
  <button
  class="search-btn"
  type="button"
  aria-label="Search"
  onclick="document.dispatchEvent(new Event('open-search'))"
>
  🔍
</button>

  <ThemeToggle />
</div>

  </div>
</header>

<SearchModal />

<style>
  .site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  backdrop-filter: blur(12px);
  background: rgba(255, 255, 255, 0.6);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

html.dark .site-header {
  background: rgba(10, 10, 10, 0.6);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-weight: 700;
    letter-spacing: 0.5px;
    font-size: 18px;
    color: white;
    text-decoration: none;
  }

  .nav {
    display: flex;
    gap: 18px;
  }

  .nav a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 14px;
    transition: 0.2s;
  }

  .nav a:hover {
    color: white;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .search-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    padding: 6px 10px;
    border-radius: 8px;
    cursor: pointer;
  }

  .search-btn:hover {
    background: rgba(255,255,255,0.08);
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }
  }
</style>