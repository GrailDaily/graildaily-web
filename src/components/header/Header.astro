---


import SearchModal from "./SearchModal.astro";
import DesktopNav from "./DesktopNav.astro";
import Logo from "./Logo.astro";
import HeaderActions from "./HeaderActions.astro";
---



<header class="site-header">
  <div class="container">
    
    <!-- Logo -->
    <Logo />

    <!-- Navigation -->
    <DesktopNav />

    <!-- Actions -->
    <HeaderActions />

  </div>
</header>

<SearchModal />

<style>
  .site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  backdrop-filter: blur(12px);
  background: rgba(255, 255, 255, 0.6);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

html.dark .site-header {
  background: rgba(10, 10, 10, 0.6);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-weight: 700;
    letter-spacing: 0.5px;
    font-size: 18px;
    color: white;
    text-decoration: none;
  }

  .nav {
    display: flex;
    gap: 18px;
  }

  .nav a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 14px;
    transition: 0.2s;
  }

  .nav a:hover {
    color: white;
  }


  @media (max-width: 768px) {
    .nav {
      display: none;
    }
  }
</style>