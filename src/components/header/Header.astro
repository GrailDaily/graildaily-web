---
import SearchModal from "./SearchModal.astro";
import DesktopNav from "./DesktopNav.astro";
import Logo from "./Logo.astro";
import HeaderActions from "./HeaderActions.astro";
import MobileMenuButton from "./MobileMenuButton.astro";
import MobileDrawer from "./MobileDrawer.astro";
---

<header class="site-header">
  <div class="app-layout header-inner">
    <Logo />

    <DesktopNav />

    <HeaderActions />

    <MobileMenuButton />
  </div>
</header>

<SearchModal />
<MobileDrawer />

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;

    backdrop-filter: blur(16px);

    background: color-mix(in srgb, var(--background) 88%, transparent);

    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    min-height: 76px;

    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-weight: 700;
    letter-spacing: 0.5px;
    font-size: 18px;
    color: white;
    text-decoration: none;
  }

  .nav {
    display: flex;
    gap: 18px;
  }

  .nav a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 14px;
    transition: 0.2s;
  }

  .nav a:hover {
    color: white;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }
  }
</style>
