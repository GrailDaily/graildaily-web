---
import "@pagefind/default-ui/css/ui.css";
import "./Search.css";
import { getAssetPath } from "@/utils/withBase";

const pagefindBundlePath = getAssetPath("pagefind/");
---

<div id="search-modal" class="search-modal hidden">
  <div class="search-backdrop"></div>

  <div class="search-panel">
    <button
      id="search-close"
      type="button"
      aria-label="Close search"
      class="search-close"
    >
      ✕
    </button>

    <div id="pagefind-modal-search" data-bundle-path={pagefindBundlePath}></div>
  </div>
</div>

<script>
  import { initSearch } from "@/scripts/pagefind";

  function getElements() {
    const modal = document.getElementById("search-modal");
    const closeButton = document.getElementById("search-close");
    const backdrop = modal?.querySelector(".search-backdrop");

    return { modal, closeButton, backdrop };
  }

  async function openSearch() {
    const { modal } = getElements();
    if (!modal) return;

    modal.classList.remove("hidden");
    document.body.style.overflow = "hidden";

    await initSearch("#pagefind-modal-search");

    requestAnimationFrame(() => {
      const input = document.querySelector<HTMLInputElement>(
        ".pagefind-ui__search-input"
      );

      if (input) {
        input.placeholder = "Search articles, topics, or keywords...";
        input.focus();
      }
    });
  }

  function closeSearch() {
    const { modal } = getElements();
    if (!modal) return;

    modal.classList.add("hidden");
    document.body.style.overflow = "";
  }

  function initSearchModal() {
    const { closeButton, backdrop } = getElements();

    document.removeEventListener("open-search", openSearch);
    document.addEventListener("open-search", openSearch);

    closeButton?.removeEventListener("click", closeSearch);
    closeButton?.addEventListener("click", closeSearch);

    backdrop?.removeEventListener("click", closeSearch);
    backdrop?.addEventListener("click", closeSearch);
  }

  initSearchModal();

  document.addEventListener("astro:after-swap", () => {
    initSearchModal();
  });

  document.addEventListener("keydown", e => {
    if (e.key === "Escape") {
      closeSearch();
      return;
    }

    if (e.key !== "/") return;

    const target = e.target as HTMLElement | null;

    if (
      target instanceof HTMLInputElement ||
      target instanceof HTMLTextAreaElement ||
      target?.isContentEditable
    ) {
      return;
    }

    e.preventDefault();

    openSearch();
  });
</script>
