---
import { navigation } from "./navigation";
---

<nav class="nav">
  {
    navigation.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))
  }
</nav>

<style>
.nav {
  display: flex;
  gap: 18px;
}

.nav a {
  color: rgba(255, 255, 255, 0.75);
  text-decoration: none;
  font-size: 14px;
  transition: 0.2s;
}

.nav a:hover {
  color: white;
}

@media (max-width: 768px) {
  .nav {
    display: none;
  }
}
</style>