---
import { navigation } from "./navigation";
const currentPath = Astro.url.pathname;
---

<nav class="nav">
  {
    navigation.map(item => {
      const isActive =
        item.href === "/"
          ? currentPath === "/"
          : currentPath.startsWith(item.href);

      return (
        <a
          href={item.href}
          class:list={{
            active: isActive,
          }}
        >
          {item.label}

          {item.label === "Categories" && (
            <span class="nav-chevron" aria-hidden="true">
              ▾
            </span>
          )}
        </a>
      );
    })
  }
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav a {
    display: flex;
    align-items: center;
    justify-content: center;

    min-height: 44px;
    padding: 0 14px;

    font-size: 15px;
    font-weight: 500;

    color: var(--foreground);

    text-decoration: none;

    border-radius: 8px;

    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .nav a:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .nav a.active {
    color: var(--accent);

    font-weight: 600;

    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .nav-chevron {
    margin-left: 4px;

    font-size: 0.9rem;

    line-height: 1;

    opacity: 0.75;

    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .nav a:hover .nav-chevron {
    opacity: 1;
    transform: translateY(1px);
  }

  .nav a.active .nav-chevron {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }
  }
</style>
