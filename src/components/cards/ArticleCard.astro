---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
  variant?: "featured" | "horizontal" | "horizontal-small" | "compact";
}

const { post, variant = "compact" } = Astro.props;
---

<a href={`/posts/${post.id}/`} class="article-link">
  <article
    class:list={{
      "article-card": true,
      compact: variant === "compact",
      featured: variant === "featured",
      horizontal: variant === "horizontal",
      "horizontal-small": variant === "horizontal-small",
    }}
  >
    {
      post.data.ogImage && (
        <div class="thumbnail">
          <img src={post.data.ogImage} alt={post.data.title} loading="lazy" />
        </div>
      )
    }
    <div class="content">
      <h3>{post.data.title}</h3>

      <p class="excerpt">
        {post.data.description}
      </p>

      <div class="meta">
        <span class="tag">
          {post.data.tags?.[0] ?? "General"}
        </span>

        <span>•</span>

        <time datetime={post.data.pubDatetime.toISOString()}>
          {
            post.data.pubDatetime.toLocaleDateString("en-US", {
              day: "numeric",
              month: "short",
              year: "numeric",
            })
          }
        </time>

        <span>•</span>

        <span>5 min read</span>
      </div>
    </div>
  </article>
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;

    height: 100%;

    box-sizing: border-box;

    padding: 18px;

    border-radius: 14px;

    border: 1px solid var(--border);

    background: color-mix(in srgb, var(--background) 96%, white 4%);

    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .article-card:hover {
    transform: translateY(-4px);

    border-color: var(--accent);

    background: color-mix(in srgb, var(--background) 92%, white 8%);
  }

  .article-card h3 {
    font-size: 1.05rem;
    line-height: 1.4;

    min-height: 3em;

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .excerpt {
    margin-top: 0.75rem;

    color: var(--muted-foreground);

    line-height: 1.7;

    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;

    overflow: hidden;

    min-height: 5.2em;
  }

  .meta {
    margin-top: auto;

    display: flex;

    align-items: center;

    flex-wrap: wrap;

    gap: 0.5rem;

    padding-top: 18px;

    font-size: 0.875rem;

    color: var(--muted-foreground);
  }

  .tag {
    color: var(--accent);
    font-weight: 600;
  }

  time {
    white-space: nowrap;
  }

  .article-card.compact {
    padding: 14px;
  }

  .article-card.compact h3 {
    font-size: 0.95rem;
  }

  .article-card.compact .excerpt {
    font-size: 0.85rem;
  }

  .thumbnail {
    display: block;

    width: 100%;

    aspect-ratio: 16/9;

    overflow: hidden;

    border-radius: 10px;

    margin-bottom: 14px;
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s ease;
  }

  .article-card:hover .thumbnail img {
    transform: scale(1.03);
  }

  .article-link {
    display: block;
    text-decoration: none;
    color: inherit;

    flex: 0 0 calc((100% - 56px) / 5);
    min-width: calc((100% - 56px) / 5);
  }

  @media (max-width: 1024px) {
    .article-link {
      flex: 0 0 calc((100% - 28px) / 3);
      min-width: calc((100% - 28px) / 3);
    }
  }

  @media (max-width: 768px) {
    .article-link {
      flex: 0 0 85%;
      min-width: 85%;
    }
  }

  @media (max-width: 480px) {
    .article-link {
      flex: 0 0 92%;
      min-width: 92%;
    }
  }

  .article-link:hover {
    text-decoration: none;
  }

  .article-card.horizontal {
    display: grid;

    grid-template-columns: 260px 1fr;

    gap: 22px;

    align-items: stretch;

    padding: 16px;
  }

  .article-card.horizontal-small {
    display: grid;
    grid-template-columns: 170px 1fr;
    gap: 14px;
    align-items: center;
    padding: 12px;
  }

  .article-card.horizontal-small .thumbnail {
    margin: 0;
    width: 100%;
    height: 110px;
    aspect-ratio: auto;
    border-radius: 10px;
  }

  .article-card.horizontal-small .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-card.horizontal-small .content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .article-card.horizontal-small h3 {
    margin: 0;
    min-height: auto;
    font-size: 1rem;
    line-height: 1.35;

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card.horizontal-small .excerpt {
    margin-top: 8px;
    font-size: 0.9rem;
    line-height: 1.5;

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card.horizontal-small .meta {
    margin-top: 10px;
    padding-top: 0;
    font-size: 0.8rem;
  }

  .article-card.horizontal .thumbnail {
    margin: 0;

    width: 100%;

    height: 180px;

    aspect-ratio: auto;

    overflow: hidden;

    border-radius: 12px;
  }

  .article-card.horizontal .thumbnail img {
    width: 100%;

    height: 100%;

    object-fit: cover;
  }

  .article-card.horizontal .content {
    display: flex;

    flex-direction: column;

    justify-content: center;
  }

  .article-card.horizontal h3 {
    min-height: auto;

    margin: 0;

    font-size: 1.35rem;

    -webkit-line-clamp: 2;
  }

  .article-card.horizontal .excerpt {
    margin-top: 12px;

    min-height: auto;

    -webkit-line-clamp: 3;
  }

  .article-card.horizontal .meta {
    margin-top: 18px;

    padding-top: 0;
  }

  @media (max-width: 768px) {
    .article-card.horizontal {
      grid-template-columns: 1fr;
    }

    .article-card.horizontal .thumbnail {
      height: 220px;
    }
  }
</style>
