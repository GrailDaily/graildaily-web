---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
---

<a href={`/posts/${post.id}/`} class="featured-card">
  <div class="featured-image">
    <img src={post.data.ogImage} alt={post.data.title} loading="lazy" />

    <div class="featured-overlay">
      <div class="featured-content">
        <h3>{post.data.title}</h3>

        <p>{post.data.description}</p>
      </div>
    </div>
  </div>
</a>
<style>
  .featured-card {
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    border-radius: 18px;
    border: 1px solid var(--border);
  }

  .featured-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-card img {
    transition: transform 0.35s ease;
  }

  .featured-content {
    max-width: 70%;

    display: flex;
    flex-direction: column;

    color: white;
  }

  .featured-content h3 {
    margin: 0;

    font-size: 1.38rem;

    font-weight: 700;

    line-height: 1.3;

    color: white;

    display: -webkit-box;

    -webkit-line-clamp: 1;

    -webkit-box-orient: vertical;

    overflow: hidden;
  }

  .featured-content p {
    margin-top: 10px;

    font-size: 0.94rem;

    line-height: 1.6;

    color: rgba(255, 255, 255, 0.88);

    display: -webkit-box;

    -webkit-line-clamp: 2;

    -webkit-box-orient: vertical;

    overflow: hidden;
  }

  .featured-card:hover h3 {
    color: var(--accent);
  }

  .featured-card:hover img {
    transform: scale(1.04);
  }

  .featured-overlay {
    position: absolute;

    left: 0;
    right: 0;
    top: 0;
    bottom: 0;

    display: flex;
    align-items: flex-end;

    padding: 28px;

    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.82) 0%,
      rgba(0, 0, 0, 0.55) 28%,
      rgba(0, 0, 0, 0.22) 55%,
      transparent 82%
    );
  }
</style>
