---
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const featuredPost = posts[0];
---

<section class="latest-hero">
  <div class="latest-header">
    <h1>Latest Articles</h1>

    <p>
      Discover the latest discoveries, historical mysteries, scientific
      breakthroughs, and fascinating stories from around the world.
    </p>
  </div>

  {
    featuredPost && (
      <a href={`/posts/${featuredPost.id}/`} class="latest-featured">
        <img src={featuredPost.data.ogImage} alt={featuredPost.data.title} />

        <div class="featured-overlay">
          <span class="featured-badge">NEWEST ARTICLE</span>

          <h2>{featuredPost.data.title}</h2>

          <p>{featuredPost.data.description}</p>
        </div>
      </a>
    )
  }
</section>
<style>
  .latest-hero {
    padding: 0px 0 64px;
  }

  .latest-header {
    text-align: center;

    max-width: 700px;

    margin: 0 auto;
  }

  .latest-header h1 {
    margin-top: 18px;

    font-size: 3rem;
  }

  .latest-header p {
    margin-top: 16px;

    color: var(--muted-foreground);

    line-height: 1.8;
  }

  .latest-featured {
    position: relative;

    display: block;

    overflow: hidden;

    margin-top: 24px;

    aspect-ratio: 16 / 8;

    border-radius: 22px;

    border: 1px solid var(--border);

    text-decoration: none;

    color: inherit;
  }

  .latest-featured h2 {
    transition: color 0.25s ease;
  }

  .latest-featured img {
    width: 100%;

    height: 100%;

    object-fit: cover;

    transition: transform 0.35s ease;
  }

  .latest-featured:hover img {
    transform: scale(1.03);
  }

  .latest-featured:hover h2 {
    color: var(--accent);
  }

  .featured-overlay {
    position: absolute;

    inset: 0;

    display: flex;

    flex-direction: column;

    justify-content: flex-end;

    padding: 40px;

    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.62) 35%,
      rgba(0, 0, 0, 0.18) 68%,
      transparent 100%
    );
  }

  .featured-overlay h2 {
    margin: 0;

    max-width: 760px;

    font-size: clamp(2.5rem, 4vw, 4rem);

    line-height: 1.15;

    color: white;
  }

  .featured-overlay p {
    margin-top: 18px;

    max-width: 640px;

    font-size: 1.1rem;

    line-height: 1.8;

    color: rgba(255, 255, 255, 0.92);

    display: -webkit-box;

    -webkit-line-clamp: 2;

    -webkit-box-orient: vertical;

    overflow: hidden;
  }

  .featured-badge {
    align-self: flex-start;

    padding: 8px 18px;

    border-radius: 999px;

    background: rgba(214, 176, 102, 0.18);

    border: 1px solid rgba(214, 176, 102, 0.45);

    backdrop-filter: blur(8px);

    color: var(--accent);

    font-size: 0.78rem;

    font-weight: 700;

    letter-spacing: 0.08em;

    text-transform: uppercase;

    margin-bottom: 22px;
  }

  .latest-featured:hover .featured-overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.92),
      rgba(0, 0, 0, 0.68),
      rgba(0, 0, 0, 0.24),
      transparent
    );
  }

  @media (max-width: 768px) {
    .latest-hero {
      padding-bottom: 40px;
    }

    .latest-header h1 {
      font-size: 2.2rem;
    }

    .latest-header p {
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .latest-featured {
      margin-top: 20px;
      aspect-ratio: 4 / 5;
    }

    .featured-overlay {
      padding: 24px;
    }

    .featured-overlay h2 {
      font-size: 1.8rem;
    }

    .featured-overlay p {
      font-size: 0.95rem;
      line-height: 1.6;

      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .featured-badge {
      font-size: 0.72rem;
      padding: 7px 14px;
    }
  }
</style>
