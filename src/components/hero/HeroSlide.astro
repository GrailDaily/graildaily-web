---
interface Props {
  title: string;
  description: string;
  category: string;
  image?: string;
  href: string;
}

const { title, description, category, image, href } = Astro.props;
---

<section class="hero-slide">
  <div class="hero-container">
    <div class="hero-left">
      <span class="hero-category">
        {category}
      </span>

      <h1>{title}</h1>

      <p>{description}</p>

      <a href={href} class="hero-button"> Read Article → </a>
    </div>
    <div class="hero-right">
      {
        image ? (
          <img src={image} alt={title} class="hero-image" />
        ) : (
          <div class="hero-image placeholder" />
        )
      }
    </div>
  </div>
</section>

<style>
  .hero-slide {
    position: relative;
    min-height: 680px;
    overflow: hidden;

    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 92%,
      transparent 100%
    );

    mask-image: linear-gradient(to bottom, #000 0%, #000 92%, transparent 100%);
  }

  .hero-container {
    width: 100%;
    max-width: 1400px;

    margin: 0 auto;

    height: 680px;

    display: flex;
    align-items: center;

    position: relative;

    padding: 0 clamp(32px, 5vw, 72px);
  }

  .hero-category {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 999px;
    background: #d6b06622;
    color: #d6b066;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .hero-left h1 {
    margin: 18px 0 24px;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 1.1;
  }

  .hero-left p {
    max-width: 560px;
    line-height: 1.8;
    color: #94a3b8;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;

    margin-top: 32px;

    padding: 0;

    background: none;
    color: #ffffff;

    font-weight: 700;
    text-decoration: none;
  }

  .hero-image {
    width: 100%;
    height: 100%;

    object-fit: cover;
    object-position: 65% center;
  }

  .hero-right::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;

    background: linear-gradient(
      90deg,
      #0b1220 0%,
      rgba(11, 18, 32, 0.88) 15%,
      rgba(11, 18, 32, 0.6) 32%,
      rgba(11, 18, 32, 0.3) 48%,
      rgba(11, 18, 32, 0.1) 62%,
      transparent 78%
    );

    z-index: 2;
  }

  .hero-left {
    min-width: 0;
    position: relative;
    z-index: 3;
    width: 540px;
  }

  .hero-right {
    position: absolute;
    inset: 0;
    top: 0;
    height: 100%;
    z-index: 1;
  }

  .hero-right img {
    width: 100%;
    height: 100%;
    max-width: none;
  }

  @media (max-width: 960px) {
    .hero-slide {
      grid-template-columns: 1fr;
    }
  }
</style>
