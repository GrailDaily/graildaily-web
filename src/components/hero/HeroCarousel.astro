---
import HeroSlide from "./HeroSlide.astro";
---

<section class="hero-carousel">

  <HeroSlide
    category="History"
    title="Discover the World's Greatest Mysteries"
    description="Deep-dive articles about ancient civilizations, archaeology, science, and unexplained phenomena."
    href="/posts"
  />

</section>

<style>

.hero-carousel{
  padding:50px 0;
}

.hero-slide{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:60px;
  align-items:center;
  min-height:520px;
}

.hero-category{
  display:inline-block;
  padding:8px 16px;
  border-radius:999px;
  background:#D6B06622;
  color:#D6B066;
  font-size:13px;
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:.08em;
}

.hero-left h1{
  margin:24px 0 20px;
  font-size:clamp(3rem,5vw,4.5rem);
  line-height:1.05;
}

.hero-left p{
  font-size:18px;
  line-height:1.8;
  max-width:560px;
}

.hero-button{
  display:inline-block;
  margin-top:34px;
  padding:14px 24px;
  border-radius:12px;
  background:#D6B066;
  color:#142A4A;
  font-weight:700;
  text-decoration:none;
}

.hero-right{
  display:flex;
  justify-content:center;
}

.hero-image{
  width:100%;
  aspect-ratio:16/10;
  border-radius:24px;
  background:#1E293B;
}

@media(max-width:960px){

.hero-slide{
  grid-template-columns:1fr;
}

}

</style>