---
import { getCollection } from "astro:content";
import { getSortedPosts } from "@/utils/getSortedPosts";
import HeroSlide from "./HeroSlide.astro";

const posts = getSortedPosts(await getCollection("posts"))
  .filter(post => post.data.featured)
  .slice(0, 6);
---

<section class="hero-carousel">
  <div class="hero-track">
    {
      posts.map(post => (
        <div class="hero-item">
          <HeroSlide
            category={post.data.tags?.[0] ?? "History"}
            title={post.data.title}
            description={post.data.description}
            image={
              typeof post.data.ogImage === "string" ? post.data.ogImage : ""
            }
            href={`/posts/${post.id}/`}
          />
        </div>
      ))
    }
  </div>

  <div class="hero-dots">
    {
      posts.map((_, i) => (
        <button
          class={`hero-dot ${i === 0 ? "active" : ""}`}
          data-index={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))
    }
  </div>
</section>

<script>
  const track = document.querySelector(".hero-track") as HTMLElement | null;
  const slides = [...document.querySelectorAll(".hero-item")];
  const dots = [...document.querySelectorAll(".hero-dot")];

  if (track && slides.length) {
    let index = 0;
    let startX = 0;
    let isDragging = false;

    function updateSlider() {
      if (!track) return;

      track.style.transform = `translateX(-${index * 100}%)`;

      dots.forEach((dot, i) => {
        dot.classList.toggle("active", i === index);
      });
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        index = i;
        updateSlider();
      });
    });

    // Mouse drag
    track.addEventListener("mousedown", e => {
      startX = e.clientX;
      isDragging = true;
    });

    window.addEventListener("mouseup", e => {
      if (!isDragging) return;

      const distance = e.clientX - startX;

      if (distance > 80 && index > 0) {
        index--;
      } else if (distance < -80 && index < slides.length - 1) {
        index++;
      }

      updateSlider();
      isDragging = false;
    });

    // Touch swipe
    track.addEventListener("touchstart", e => {
      startX = e.touches[0].clientX;
    });

    track.addEventListener("touchend", e => {
      const distance = e.changedTouches[0].clientX - startX;

      if (distance > 80 && index > 0) {
        index--;
      } else if (distance < -80 && index < slides.length - 1) {
        index++;
      }

      updateSlider();
    });

    // Auto slide
    setInterval(() => {
      index = (index + 1) % slides.length;
      updateSlider();
    }, 6000);
  }
</script>

<style>
  .hero-carousel {
    overflow: hidden;
    position: relative;

    margin: 0;
    padding: 0;
  }

  .hero-track {
    display: flex;
    transition: transform 0.45s ease;
    position: relative;
    cursor: grab;
    user-select: none;
    touch-action: pan-y;
  }

  .hero-track:active {
    cursor: grabbing;
  }

  .hero-item {
    flex: 0 0 100%;
    min-width: 100%;
  }

  .hero-carousel {
    max-width: 100%;
  }

  .hero-dots {
    position: absolute;

    left: calc(50% - 600px + 24px);

    bottom: 90px;

    display: flex;
    gap: 10px;

    justify-content: flex-start;

    z-index: 20;
  }

  .hero-dot {
    width: 10px;

    height: 10px;

    border-radius: 50%;

    border: none;

    background: #475569;

    cursor: pointer;

    transition: 0.25s;
  }

  .hero-dot.active {
    background: #d6b066;

    transform: scale(1.3);
  }
</style>
