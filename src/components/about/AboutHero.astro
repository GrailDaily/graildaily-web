---
import aboutHero from "@/assets/images/about/about-hero.png";
---

<section class="about-hero">
  <div class="about-hero-container">
    <div class="about-header">
      <h1>About GrailDaily</h1>

      <p>
        Exploring history, archaeology, science, and the mysteries that shape
        our world.
      </p>
    </div>

    <div class="hero-image">
      <img src={aboutHero.src} alt="About GrailDaily" loading="eager" />
    </div>
  </div>
</section>
<style>
  .about-hero {
    padding-top: 24px;
  }

  .about-header {
    max-width: 820px;

    margin: 0 auto 32px;

    text-align: center;
  }

  .about-header h1 {
    font-size: 3rem;
  }

  .about-header p {
    margin-top: 16px;

    color: var(--muted-foreground);

    line-height: 1.8;
  }

  .hero-image {
    height: 480px;

    overflow: hidden;

    border-radius: 24px;

    border: 1px solid var(--border);
  }

  .hero-image img {
    width: 100%;
    height: 100%;

    display: block;

    object-fit: fill;
  }

  .about-hero-container {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0 24px;
  }
</style>
