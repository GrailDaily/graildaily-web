
---
import { getCollection } from "astro:content";

const posts = await getCollection("posts");

const featured = posts
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  )[0];
---

<section class="hero">
  <div class="hero-container">

    <div class="hero-content">

      <span class="hero-badge">
        Exploring History, Science & Mysteries
      </span>

      <h1>
        Discover the World's Greatest Mysteries &
        Hidden Knowledge
      </h1>

      <p>
        Deep-dive articles about ancient civilizations,
        unexplained phenomena, archaeology,
        forgotten history, and scientific discoveries.
      </p>

      <div class="hero-buttons">
        <a href="/posts" class="primary">
          Read Articles
        </a>

        <a href="/about" class="secondary">
          About Project
        </a>
      </div>

    </div>

    <div class="hero-featured">

      <a class="featured-card" href={`/posts/${featured.id}/`}>

        <div class="featured-image">
  {
    featured.data.ogImage && (
      <img
  src={
    typeof featured.data.ogImage === "string"
      ? featured.data.ogImage
      : featured.data.ogImage?.src
  }
  alt={featured.data.title}
  class="featured-cover"
  loading="lazy"
/>
    )
  }
</div>

        <div class="featured-content">

          <span class="featured-tag">
            Featured Article
          </span>

          <h3>{featured.data.title}</h3>

          <p>
            {featured.data.author}
        </p>

        </div>

      </a>

    </div>

  </div>
</section>

<style>
    .hero {
  padding: 48px 20px 60px;
}

.hero-featured{

    max-width:520px;

    justify-self:end;

    width:100%;

    transition:
transform .25s ease,
box-shadow .25s ease;

}

.hero-container {
  max-width: 1200px;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1.1fr .9fr;
  gap: 56px;
  align-items: center;
}

.featured-card:hover{

transform:translateY(-6px);

box-shadow:
0 18px 40px rgba(0,0,0,.25);

}

.hero-content {
  max-width: 760px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;

  padding: 6px 14px;

  border: 1px solid rgba(255,255,255,.12);
  border-radius: 999px;

  font-size: 12px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;

  color: rgba(255,255,255,.75);

  background: rgba(255,255,255,.04);
}

.hero-content h1 {
  margin-top: 22px;
  margin-bottom: 20px;

  font-size: clamp(2.8rem, 6vw, 4.8rem);
  line-height: 1.05;
  font-weight: 800;

  color: #fff;

  max-width: 900px;
}

.hero-content p {
  max-width: 640px;

  font-size: 18px;
  line-height: 1.8;

  color: rgba(255,255,255,.70);
}

.hero-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;

  margin-top: 36px;
}

.primary,
.secondary {
  padding: 14px 22px;

  border-radius: 12px;

  text-decoration: none;

  font-weight: 600;

  transition: .25s;
}

.primary {
  background: #ffffff;
  color: #000000;
}

.primary:hover {
  transform: translateY(-2px);
}

.secondary {
  border: 1px solid rgba(255,255,255,.15);

  color: white;

  background: rgba(255,255,255,.04);
}

.secondary:hover {
  background: rgba(255,255,255,.08);
}

.featured-card {
  overflow: hidden;

  border-radius: 22px;

  border: 1px solid rgba(255,255,255,.08);

  background: rgba(255,255,255,.03);

  backdrop-filter: blur(14px);
}

.featured-image {
  aspect-ratio: 16 / 9;

  background:
    linear-gradient(
      135deg,
      rgba(255,255,255,.10),
      rgba(255,255,255,.02)
    );
}

.featured-content {
  padding: 28px;
}

.featured-tag {
  font-size: 12px;

  text-transform: uppercase;

  letter-spacing: .08em;

  color: rgba(255,255,255,.55);
}

.featured-content h3 {
  margin-top: 12px;
  margin-bottom: 14px;

  font-size: 30px;
  line-height: 1.3;

  color: white;
}

.featured-content p {
  color: rgba(255,255,255,.60);
}

@media (max-width:768px){

  .hero{
      padding:56px 20px;
  }

  .hero-content h1{
      font-size:42px;
  }

  .hero-content p{
      font-size:16px;
  }

}
.featured-image {
  aspect-ratio: 16 / 9;
  overflow: hidden;
}

.featured-cover {
  width: 100%;
  height: 100%;

  object-fit: cover;

  display: block;

  transition: transform .4s ease;
}

.featured-card:hover .featured-cover {
  transform: scale(1.05);
}

@media (max-width: 960px) {

  .hero-container {

    grid-template-columns: 1fr;

  }

}
</style>