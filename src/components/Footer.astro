---
import logoLight from "@/assets/images/logo/logo-light.png";
import logoDark from "@/assets/images/logo/logo-dark.png";
import "@/styles/footer.css";
import Socials from "./Socials.astro";
---

<footer class="footer">
  <div class="footer-container">
    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src={logoLight.src} alt="GrailDaily" class="footer-logo-light" />

        <img src={logoDark.src} alt="GrailDaily" class="footer-logo-dark" />
      </a>

      <p class="footer-description">
        Exploring history, science, mysteries, and forgotten knowledge for
        curious minds around the world.
      </p>

      <div class="footer-social">
        <Socials />
      </div>
    </div>

    <!-- About -->
    <nav class="footer-column" aria-label="Footer navigation">
      <h3>Company</h3>

      <ul>
        <li><a href="/about">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/rss.xml">RSS Feed</a></li>
        <li><a href="/privacy-policy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of Service</a></li>
      </ul>
    </nav>

    <!-- Map -->
    <div class="footer-map">
      <img src="/images/worldmap.png" alt="World Map" />

      <p>Connecting curious minds around the world.</p>
    </div>

    <div class="footer-bottom">
      © {new Date().getFullYear()} GrailDaily. All rights reserved.
    </div>
  </div>
</footer>
