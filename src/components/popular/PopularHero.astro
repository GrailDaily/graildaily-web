---
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const featuredPost = posts[0];

interface Props {
  range: string;
}

const { range } = Astro.props;
console.log("Range =", range);
---

<section class="popular-hero">
  <div class="app-layout">
    <div class="popular-header">
      <h1>Popular Articles</h1>

      <p>
        Discover the stories that readers around the world are exploring the
        most.
      </p>
    </div>

    <nav class="popular-filter">
      <a href="/popular/all" class:list={{ active: range === "all" }}>
        All Time
      </a>

      <a href="/popular/month" class:list={{ active: range === "month" }}>
        This Month
      </a>

      <a href="/popular/week" class:list={{ active: range === "week" }}>
        This Week
      </a>

      <a href="/popular/today" class:list={{ active: range === "today" }}>
        Today
      </a>
    </nav>

    {
      featuredPost && (
        <a href={`/posts/${featuredPost.id}/`} class="popular-featured">
          <img src={featuredPost.data.ogImage} alt={featuredPost.data.title} />

          <div class="featured-overlay">
            <span class="featured-badge">#1 MOST READ</span>

            <h2>{featuredPost.data.title}</h2>

            <p>{featuredPost.data.description}</p>
          </div>
        </a>
      )
    }
  </div>
</section>
<style>
  .popular-hero {
    padding: 0px 0;
  }

  .popular-header {
    text-align: center;

    max-width: 700px;

    margin: 0 auto;
  }

  .popular-header h1 {
    margin-top: 18px;

    font-size: 3rem;
  }

  .popular-header p {
    margin-top: 16px;

    color: var(--muted-foreground);

    line-height: 1.8;
  }

  .popular-filter {
    display: flex;

    justify-content: center;

    gap: 14px;

    margin-top: 36px;
  }

  .popular-filter a {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 10px 18px;

    border-radius: 999px;

    border: 1px solid var(--border);

    background: transparent;

    color: var(--foreground);

    text-decoration: none;

    transition: all 0.2s ease;
  }

  .popular-filter .active {
    background: var(--accent);

    color: white;
  }

  .popular-filter a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .popular-featured {
    position: relative;

    display: block;

    overflow: hidden;

    margin-top: 24px;

    aspect-ratio: 16 / 8;

    border-radius: 22px;

    border: 1px solid var(--border);

    text-decoration: none;

    color: inherit;
  }

  .popular-featured h2 {
    transition: color 0.25s ease;
  }

  .popular-featured img {
    width: 100%;

    height: 100%;

    object-fit: cover;

    transition: transform 0.35s ease;
  }

  .popular-featured:hover img {
    transform: scale(1.03);
  }

  .popular-featured:hover h2 {
    color: var(--accent);
  }

  .featured-overlay {
    position: absolute;

    inset: 0;

    display: flex;

    flex-direction: column;

    justify-content: flex-end;

    padding: 40px;

    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.62) 35%,
      rgba(0, 0, 0, 0.18) 68%,
      transparent 100%
    );
  }

  .featured-overlay h2 {
    margin: 0;

    max-width: 760px;

    font-size: clamp(2.5rem, 4vw, 4rem);

    line-height: 1.15;

    color: white;
  }

  .featured-overlay p {
    margin-top: 18px;

    max-width: 640px;

    font-size: 1.1rem;

    line-height: 1.8;

    color: rgba(255, 255, 255, 0.92);

    display: -webkit-box;

    -webkit-line-clamp: 2;

    -webkit-box-orient: vertical;

    overflow: hidden;
  }

  .featured-badge {
    align-self: flex-start;

    padding: 8px 18px;

    border-radius: 999px;

    background: rgba(214, 176, 102, 0.18);

    border: 1px solid rgba(214, 176, 102, 0.45);

    backdrop-filter: blur(8px);

    color: var(--accent);

    font-size: 0.78rem;

    font-weight: 700;

    letter-spacing: 0.08em;

    text-transform: uppercase;

    margin-bottom: 22px;
  }

  .popular-featured:hover .featured-overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.92),
      rgba(0, 0, 0, 0.68),
      rgba(0, 0, 0, 0.24),
      transparent
    );
  }

  @media (max-width: 768px) {
    .popular-header h1 {
      font-size: 2.2rem;
    }

    .popular-header p {
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .popular-filter {
      margin-top: 24px;

      display: flex;
      justify-content: flex-start;

      overflow-x: auto;

      gap: 10px;

      padding-bottom: 6px;

      scrollbar-width: none;
    }

    .popular-filter::-webkit-scrollbar {
      display: none;
    }

    .popular-filter a {
      flex-shrink: 0;

      white-space: nowrap;

      padding: 10px 16px;
    }

    .popular-featured {
      margin-top: 20px;

      aspect-ratio: 16 / 10;
    }

    .featured-overlay {
      padding: 24px;
    }

    .featured-overlay h2 {
      font-size: clamp(1.5rem, 5vw, 2rem);
      line-height: 1.25;
    }

    .featured-overlay p {
      font-size: 0.95rem;

      line-height: 1.6;

      -webkit-line-clamp: 3;
    }
  }

  @media (max-width: 480px) {
    .popular-header h1 {
      font-size: 1.9rem;
    }

    .popular-header p {
      font-size: 0.9rem;
    }

    .popular-filter a {
      padding: 9px 14px;
      font-size: 0.9rem;
    }

    .featured-overlay {
      padding: 18px;
    }

    .featured-overlay h2 {
      font-size: 1.45rem;
    }

    .featured-overlay p {
      font-size: 0.88rem;
      -webkit-line-clamp: 2;
    }
  }
</style>
