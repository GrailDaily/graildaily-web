---
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;
---

<section class="popular-list">
  <div class="popular-section-header">
    <span class="section-label"> MORE STORIES </span>

    <h2>More Popular Articles</h2>

    <p>
      Continue exploring the stories readers love, from timeless history and
      archaeology to science, mysteries, and fascinating discoveries.
    </p>
  </div>

  {
    posts.map((post, index) => (
      <a href={`/posts/${post.id}/`} class="popular-row">
        <span class="rank">{String(index + 6).padStart(2, "0")}</span>

        <img src={post.data.ogImage} alt={post.data.title} loading="lazy" />

        <div class="row-content">
          <h3>{post.data.title}</h3>

          <p>{post.data.description}</p>
        </div>
      </a>
    ))
  }
</section>

<style>
  .popular-list {
    margin-top: 80px;
  }

  .popular-list h2 {
    margin-bottom: 28px;

    font-size: 2rem;
  }

  .popular-row {
    display: grid;

    grid-template-columns: 70px 180px 1fr;

    gap: 22px;

    align-items: center;

    padding: 22px 18px;

    border-bottom: 1px solid var(--border);

    text-decoration: none;

    color: inherit;

    transition: 0.25s;

    overflow: hidden;
  }

  .popular-row:hover {
    background: color-mix(in srgb, var(--accent) 5%, transparent);

    border-radius: 14px;
  }

  .rank {
    font-size: 2.4rem;

    font-weight: 800;

    color: var(--accent);

    opacity: 0.85;

    letter-spacing: -1px;
  }

  .popular-row img {
    width: 180px;

    aspect-ratio: 16/10;

    object-fit: cover;

    border-radius: 10px;

    transition: transform 0.3s;
  }

  .popular-row:hover img {
    transform: scale(1.03);
  }

  .row-content h3 {
    font-size: 1.28rem;

    font-weight: 700;

    line-height: 1.4;

    transition: color 0.25s ease;
  }

  .row-content p {
    margin-top: 10px;

    color: var(--muted-foreground);

    line-height: 1.7;

    display: -webkit-box;

    -webkit-line-clamp: 2;

    -webkit-box-orient: vertical;

    overflow: hidden;
  }

  .popular-row:hover h3 {
    color: var(--accent);
  }

  .popular-section-header {
    margin-bottom: 36px;

    text-align: center;
  }

  .section-label {
    display: inline-block;

    padding: 6px 14px;

    border-radius: 999px;

    background: color-mix(in srgb, var(--accent) 15%, transparent);

    color: var(--accent);

    font-size: 0.8rem;

    font-weight: 700;

    letter-spacing: 0.08em;

    text-transform: uppercase;
  }

  .popular-section-header h2 {
    margin-top: 18px;

    font-size: clamp(2rem, 3vw, 2.6rem);

    line-height: 1.2;
  }

  .popular-section-header p {
    margin: 16px auto 0;

    max-width: 700px;

    color: var(--muted-foreground);

    line-height: 1.8;
  }

  /* ===========================
   Tablet
=========================== */

  @media (max-width: 1024px) {
    .popular-row {
      grid-template-columns: 60px 150px 1fr;
      gap: 18px;
    }

    .popular-row img {
      width: 150px;
    }

    .rank {
      font-size: 2rem;
    }

    .row-content h3 {
      font-size: 1.15rem;
    }
  }

  /* ===========================
   Mobile
=========================== */

  @media (max-width: 768px) {
    .popular-list {
      margin-top: 56px;
    }

    .popular-section-header {
      margin-bottom: 26px;
    }

    .popular-section-header h2 {
      font-size: 1.9rem;
    }

    .popular-section-header p {
      font-size: 0.95rem;
      line-height: 1.7;
      padding: 0 6px;
    }

    .popular-row {
      grid-template-columns: 46px 120px 1fr;
      gap: 14px;
      padding: 16px 0;
    }

    .rank {
      font-size: 1.7rem;
    }

    .popular-row img {
      width: 120px;
    }

    .row-content h3 {
      font-size: 1rem;
      line-height: 1.45;
    }

    .row-content p {
      margin-top: 8px;
      font-size: 0.9rem;
      line-height: 1.6;

      -webkit-line-clamp: 3;
    }
  }

  /* ===========================
   Small Mobile
=========================== */

  @media (max-width: 480px) {
    .popular-row {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 18px 0;
    }

    .rank {
      font-size: 1.5rem;
    }

    .popular-row img {
      width: 100%;
    }

    .row-content h3 {
      font-size: 1rem;
    }

    .row-content p {
      -webkit-line-clamp: 2;
    }
  }
</style>
